# Copy this file to .env and fill in your keys.

# LLM Provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Tavily search API — get a free key at https://tavily.com
# Without this key the pipeline uses dummy search results.
TAVILY_API_KEY=tvly-...

# Pipeline tuning
TOP_OPPORTUNITIES=3        # how many opportunities to pitch
REFINE_ITERATIONS=2        # how many critic/refiner loops per pitch
REPORTS_DIR=reports        # output directory (relative to saas_scout/)
